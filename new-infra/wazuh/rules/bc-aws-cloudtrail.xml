<!--
  bc-aws-cloudtrail.xml — Custom Wazuh rules for AWS CloudTrail telemetry.

  Rule ID range: 100300-100399 (reserved for bc-aws)
  Telemetry source: wodle aws-s3 module on the Wazuh manager, reading the
                    bc-cloudtrail-logs S3 bucket. Decoded by the built-in
                    Wazuh decoder "aws-cloudtrail".

  Deployed to: /var/ossec/etc/rules/bc-aws-cloudtrail.xml on the manager
               by phase3-install-wazuh.sh on instance boot.
-->
<group name="bc-aws,cloudtrail,">

  <!-- ============================================================
       100300 — Console login without MFA
       MITRE: T1078 (Valid Accounts)
       Level 12: high severity, paged.
  ============================================================ -->
  <rule id="100300" level="12">
    <decoded_as>json</decoded_as>
    <field name="eventSource">signin.amazonaws.com</field>
    <field name="eventName">ConsoleLogin</field>
    <field name="responseElements.ConsoleLogin">Success</field>
    <field name="additionalEventData.MFAUsed">No</field>
    <description>AWS Console login without MFA — $(userIdentity.userName) from $(sourceIPAddress)</description>
    <mitre>
      <id>T1078</id>
    </mitre>
    <group>authentication,pci_dss_8.3,gdpr_IV_35.7.d,</group>
  </rule>

  <!-- ============================================================
       100301 — Root account used (any console sign-in event)
       MITRE: T1078.004 (Cloud Accounts)
       Level 15: critical, always page.
  ============================================================ -->
  <rule id="100301" level="15">
    <decoded_as>json</decoded_as>
    <field name="userIdentity.type">Root</field>
    <field name="eventType">AwsConsoleSignIn</field>
    <description>AWS root account used — CRITICAL — from $(sourceIPAddress)</description>
    <mitre>
      <id>T1078.004</id>
    </mitre>
    <group>authentication,pci_dss_10.2.2,gdpr_IV_35.7.d,</group>
  </rule>

  <!-- ============================================================
       100302 — Security Group modified
       MITRE: T1562.007 (Disable or Modify Cloud Firewall)
       Level 8: medium — review during business hours.
  ============================================================ -->
  <rule id="100302" level="8">
    <decoded_as>json</decoded_as>
    <field name="eventSource">ec2.amazonaws.com</field>
    <field name="eventName">\.*(SecurityGroup).*</field>
    <description>AWS Security Group modified — $(eventName) by $(userIdentity.userName)</description>
    <mitre>
      <id>T1562.007</id>
    </mitre>
    <group>configuration_changed,pci_dss_1.1.1,</group>
  </rule>

  <!-- ============================================================
       100303 — IAM role or policy modified outside the pipeline
       MITRE: T1136 (Create Account)
       Level 10: high — anything not GitHubActionsDeployRole is suspect.
  ============================================================ -->
  <rule id="100303" level="10">
    <decoded_as>json</decoded_as>
    <field name="eventSource">iam.amazonaws.com</field>
    <field name="eventName">\.*(Role|Policy).*</field>
    <description>AWS IAM role/policy modified — $(eventName) by $(userIdentity.userName)</description>
    <mitre>
      <id>T1136</id>
    </mitre>
    <group>configuration_changed,pci_dss_8.1,</group>
  </rule>

</group>
